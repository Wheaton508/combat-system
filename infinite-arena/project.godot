"res://scenes/management/": "orange",
"res://scenes/ui/": "orange",
"res://scripts/": "red",
"res://scripts/custom_resources/": "orange",
"res://scripts/management/": "orange",
"res://scripts/ui/": "orange",
"res://scripts/ui/buttons/": "yellow"
}

